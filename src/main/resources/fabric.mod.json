{
  "schemaVersion": 1,
  "id": "meteor-farm-addon",
  "version": "${version}",
  "name": "Range Farm Assistant",
  "description": "自动范围锄地、种植和除草 - Meteor Client 插件",
  "authors": ["Miao"],
  "contact": {
    "homepage": "https://github.com/MGHYGitHub/farm-addon",
    "issues": "https://github.com/MGHYGitHub/farm-addon/issues",
    "sources": "https://github.com/MGHYGitHub/farm-addon"
  },
  "license": "MIT",
  "icon": "assets/template/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "meteordevelopment.meteorclient.addons.farm.FarmAddon"
    ]
  },
  "custom": {
    "meteor-client:color": "45, 180, 45",
    "modmenu": {
      "badges": ["library"]
    }
  },
  "depends": {
    "java": ">=17",
    "minecraft": ">=1.20.1",
    "fabricloader": ">=0.14.0",
    "fabric": "*",
    "meteor-client": "*"
  }
}
